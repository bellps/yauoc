# Para rodar LOCALMENTE (npm run dev fora do Docker), use localhost:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yauoc?schema=public"

# Para rodar com Docker Compose, o host é "db":
# DATABASE_URL="postgresql://postgres:postgres@db:5432/yauoc?schema=public"

AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"

ADMIN_SEED_EMAIL="admin@yauoc.local"
ADMIN_SEED_PASSWORD="change-me"
ADMIN_SEED_NAME="Admin"
