# syntax=docker/dockerfile:1.7
# Dev image used by docker-compose. Includes OpenSSL so Prisma's schema
# engine detects the correct libssl version on Debian-based images.

FROM node:22-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
EXPOSE 3000
